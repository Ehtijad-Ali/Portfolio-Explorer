# ─── Stripe ───────────────────────────────────────────────
# Get these from dashboard.stripe.com/test/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Create products + prices in Stripe dashboard, paste the price IDs:
VITE_STRIPE_PRICE_PRO=price_pro_monthly_id
VITE_STRIPE_PRICE_AGENCY=price_agency_monthly_id

# ─── Analytics ────────────────────────────────────────────
# GA4 Measurement ID from analytics.google.com
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── App ──────────────────────────────────────────────────
VITE_APP_URL=https://your-deploy-url.vercel.app
